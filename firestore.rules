rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Clients
    match /clients/{clientId} {
      allow read: if isSignedIn() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId == clientId);
      allow write: if isAdmin();
    }

    // Transactions
    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId == resource.data.clientId);
      allow create: if isSignedIn() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId == request.resource.data.clientId);
      allow update, delete: if isAdmin();
    }

    // Documents
    match /documents/{docId} {
      allow read: if isSignedIn() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId == resource.data.clientId);
      allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId == request.resource.data.clientId);
    }
    
    // Inventory
    match /inventory/{itemId} {
      allow read: if isSignedIn() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId == resource.data.clientId);
      allow write: if isSignedIn() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clientId == request.resource.data.clientId);
    }

    // Leads (CRM)
    match /leads/{leadId} {
      allow read, write: if isAdmin();
    }
  }
}
